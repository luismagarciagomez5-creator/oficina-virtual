# Copia este archivo a .env y rellena los valores desde tu proyecto Supabase
# (Project Settings → API). El anon key es seguro para el frontend siempre
# que las políticas RLS estén activas (ver supabase/schema.sql).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Fase 0 del kit Hermes (opcional, ver adapters/hermes.ts). Déjalo vacío
# hasta que Codex exponga el puente real.
VITE_HERMES_ENDPOINT=

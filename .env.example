# Copia este archivo a .env y rellena los valores desde tu proyecto Supabase
# (Project Settings → API). El anon key es seguro para el frontend siempre
# que las políticas RLS estén activas (ver supabase/schema.sql).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# La conexión del Orquestador (OpenRouter / Hermes por Telegram) se gestiona
# por workspace desde el backend, no con variables VITE_* — ningún secreto
# (token de bot, API key) debe vivir en el frontend. Ver
# src/central-orchestrator/ y COORDINACION_CLAUDE_CODEX.md.
